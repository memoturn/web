{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/.turbo",
			"!**/.wrangler",
			"!**/.output",
			"!**/.tanstack",
			"!**/.nitro",
			"!**/node_modules",
			"!**/.claude",
			"!**/coverage",
			"!**/*.tsbuildinfo",
			"!**/worker-configuration.d.ts",
			"!**/routeTree.gen.ts",
			"!apps/web/src/styles.css",
			"!apps/console/src/styles.css",
			"!packages/ui/src/styles/**/*.css",
			"!apps/docs/src/styles/**/*.css",
			"!pnpm-lock.yaml"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 140,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["packages/ui/src/components/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useFocusableInteractive": "off",
						"useAriaPropsForRole": "off",
						"useKeyWithClickEvents": "off",
						"noRedundantRoles": "off"
					},
					"suspicious": {
						"noDocumentCookie": "off"
					}
				}
			}
		}
	],
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
