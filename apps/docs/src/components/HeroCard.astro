---
type Props = {
	kicker?: string;
	title: string;
	href?: string;
	code?: string;
	lang?: string;
};

const { kicker, title, href, code } = Astro.props;
---

<section class="m-hero-card">
	<div class="m-hero-card__copy">
		{kicker && <span class="m-hero-card__kicker">{kicker}</span>}
		{
			href ? (
				<a class="m-hero-card__title-link" href={href}>
					<h2 class="m-hero-card__title">{title}</h2>
				</a>
			) : (
				<h2 class="m-hero-card__title">{title}</h2>
			)
		}
		<div class="m-hero-card__body">
			<slot />
		</div>
	</div>
	{
		code && (
			<pre class="m-hero-card__code"><code>{code}</code></pre>
		)
	}
</section>

<style>
	.m-hero-card {
		display: grid;
		gap: 1.25rem;
		padding: 1.75rem;
		border-radius: var(--radius-lg);
		border: 1px solid var(--docs-line);
		background: var(--docs-panel-bg);
		margin-block: 2.25rem 1.5rem;
	}

	@media (min-width: 720px) {
		.m-hero-card {
			grid-template-columns: 1.1fr 0.9fr;
			align-items: center;
			padding: 2rem 2.25rem;
			gap: 2rem;
		}
	}

	.m-hero-card__copy {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.m-hero-card__kicker {
		font-size: 0.69rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		font-weight: 700;
		color: var(--kicker);
	}

	.m-hero-card__title-link {
		text-decoration: none;
		color: inherit;
		display: inline-block;
	}

	.m-hero-card__title-link:focus-visible {
		outline: 2px solid var(--ring);
		outline-offset: 3px;
		border-radius: var(--radius-sm);
	}

	.m-hero-card__title {
		margin: 0;
		font-family: var(--font-heading-stack);
		font-size: clamp(1.5rem, 2.6vw, 1.75rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: -0.02em;
		color: var(--foreground);
	}

	.m-hero-card__title-link:hover .m-hero-card__title {
		color: var(--primary);
	}

	.m-hero-card__body {
		font-size: 0.95rem;
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	.m-hero-card__body :global(p) {
		margin: 0;
	}

	.m-hero-card__body :global(code) {
		font-family: var(--font-mono-stack);
		font-size: 0.85em;
		font-weight: 500;
		line-height: 1.5;
		background: var(--muted);
		color: var(--primary);
		border-radius: calc(var(--radius) * 0.4);
		padding: 0.1em 0.35em;
	}

	.m-hero-card__code {
		margin: 0;
		padding: 1rem 1.25rem;
		background: var(--background);
		border: 1px solid var(--docs-line);
		border-radius: var(--radius-md);
		font-family: var(--font-mono-stack);
		font-size: 0.875rem;
		line-height: 1.55;
		color: var(--foreground);
		overflow-x: auto;
	}
</style>
