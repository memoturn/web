{
	"name": "@memoturn/ui",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./components/*": "./src/components/*.tsx",
		"./composite/*": "./src/composite/*.tsx",
		"./lib/utils": "./src/lib/utils.ts",
		"./styles/tokens.css": "./src/styles/tokens.css",
		"./styles/base.css": "./src/styles/base.css",
		"./styles": "./src/styles/index.css"
	},
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"lucide-react": "catalog:",
		"radix-ui": "catalog:",
		"sonner": "catalog:",
		"tailwind-merge": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@memoturn/tsconfig": "workspace:*",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"typescript": "catalog:"
	}
}
